            "patch": "+export function rateLimit(limiter: RateLimiter) {\n+  return (req, res, next) => {\n+    const key = parseHeaders(req.rawHeaders).get('x-api-key') ?? req.ip;\n+    const { ok, remaining } = limiter.check(key);\n+    res.setHeader('x-ratelimit-remaining', remaining);\n+    if (!ok) return res.status(429).end();\n+    next();\n+  };\n+}",
